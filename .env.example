# Backend Environment Variables
# Copy this to apps/backend/.env and fill in real values

# Server port (Render auto-sets this to 10000)
PORT=10000

# Database URL (PostgreSQL for production, SQLite for local)
# Example: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://...

# Frontend URL for CORS (set to your deployed frontend URL)
FRONTEND_URL=https://testify-frontend.onrender.com

# Session settings
SESSION_COOKIE=testify_session
SESSION_TTL_DAYS=30

# Admin auth (use CSV locally, env var in cloud)
ADMIN_CSV_PATH=data/admins.csv
ADMIN_COOKIE=testify_admin

# Cloud-only: admin credentials as JSON (for Render without CSV)
# Format: [{"email":"admin@testify.app","passwordHash":"$2a$10$...","name":"Admin"}]
# Generate hash with: npx bcryptjs hash "yourpassword" 10
ADMIN_CREDENTIALS=

# Frontend Environment Variables
# Copy this to apps/frontend/.env.local

# Backend API URL
BACKEND_URL=https://testify-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=https://testify-backend.onrender.com
