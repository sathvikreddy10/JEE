<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/test_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".TestTakingActivity">

    <!-- Floating glass header -->
    <LinearLayout
        android:id="@+id/test_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/test_title_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculus I"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ink"
                android:letterSpacing="-0.02"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/test_subtitle_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mathematics"
                android:textSize="12sp"
                android:textColor="@color/muted" />
        </LinearLayout>

        <TextView
            android:id="@+id/question_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/25"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/gold_text"
            android:background="@drawable/bg_chip"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/timer_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60:00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:background="@drawable/bg_dock"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/question_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progressDrawable="@drawable/progress_gold"
        android:progress="1"
        android:max="25"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp" />

    <!-- Question area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Question glass card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUESTION"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/question_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What is the derivative of x²?"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink"
                    android:letterSpacing="-0.02"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="22dp" />

                <RadioGroup
                    android:id="@+id/options_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/option_a_radio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2x"
                        android:textSize="15sp"
                        android:padding="17dp"
                        android:background="@drawable/btn_option"
                        android:textColor="@color/ink"
                        android:button="@null"
                        android:layout_marginBottom="10dp" />

                    <RadioButton
                        android:id="@+id/option_b_radio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="x"
                        android:textSize="15sp"
                        android:padding="17dp"
                        android:background="@drawable/btn_option"
                        android:textColor="@color/ink"
                        android:button="@null"
                        android:layout_marginBottom="10dp" />

                    <RadioButton
                        android:id="@+id/option_c_radio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="x²"
                        android:textSize="15sp"
                        android:padding="17dp"
                        android:background="@drawable/btn_option"
                        android:textColor="@color/ink"
                        android:button="@null"
                        android:layout_marginBottom="10dp" />

                    <RadioButton
                        android:id="@+id/option_d_radio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="15sp"
                        android:padding="17dp"
                        android:background="@drawable/btn_option"
                        android:textColor="@color/ink"
                        android:button="@null" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Floating dark dock -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_dock"
        android:padding="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_mark_review"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Mark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_glass_pill"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_previous"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Prev"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_glass_pill"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_skip"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Skip"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_glass_pill"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_next_submit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.4"
            android:text="Next"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_gold"
            android:textColor="@color/ink"
            android:stateListAnimator="@null" />
    </LinearLayout>
</LinearLayout>
