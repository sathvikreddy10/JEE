<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:scrollbars="none"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layoutAnimation="@anim/layout_fall_in"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_card"
                android:paddingStart="6dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/top_initial"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:text="N"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/gold_text"
                    android:gravity="center"
                    android:background="@drawable/bg_chip" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="aurex edge"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ink"
                    android:letterSpacing="-0.02"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 1-day streak"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/blush_deep"
                android:background="@drawable/bg_chip_blush"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/greeting_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hi,"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/ink"
            android:letterSpacing="-0.04"
            android:layout_marginTop="30dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="let's sharpen your edge today."
            android:textSize="20sp"
            android:textColor="@color/muted"
            android:letterSpacing="-0.02"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="24dp"
            android:layout_marginTop="26dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ 25 questions" android:textSize="12sp" android:textStyle="bold" android:textColor="#EDEBE4" android:background="@drawable/bg_glass_chip" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60 min" android:textSize="12sp" android:textStyle="bold" android:textColor="#EDEBE4" android:background="@drawable/bg_glass_chip" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="7dp" android:paddingBottom="7dp" android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Today's mock,\ndecoded by you." android:textSize="28sp" android:textStyle="bold" android:textColor="#FFFFFF" android:lineSpacingMultiplier="1.05" android:letterSpacing="-0.03" android:layout_marginTop="18dp" />

            <Button
                android:id="@+id/btn_start_test"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Start practicing  →"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_gold"
                android:textColor="@color/ink"
                android:stateListAnimator="@animator/press_scale"
                android:layout_marginTop="22dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="14dp">
            <LinearLayout android:id="@+id/btn_tests" android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_bento_butter" android:foreground="?android:attr/selectableItemBackground" android:stateListAnimator="@animator/press_scale" android:clickable="true" android:focusable="true" android:padding="18dp" android:layout_marginEnd="7dp">
                <TextView android:layout_width="42dp" android:layout_height="42dp" android:text="📝" android:textSize="19sp" android:gravity="center" android:background="@drawable/bg_icon_circle" />
                <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tests" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/ink" android:letterSpacing="-0.02" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8 papers ready" android:textSize="12sp" android:textColor="@color/butter_deep" />
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_analysis" android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_bento_mint" android:foreground="?android:attr/selectableItemBackground" android:stateListAnimator="@animator/press_scale" android:clickable="true" android:focusable="true" android:padding="18dp" android:layout_marginStart="7dp">
                <TextView android:layout_width="42dp" android:layout_height="42dp" android:text="📊" android:textSize="19sp" android:gravity="center" android:background="@drawable/bg_icon_circle" />
                <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Analysis" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/ink" android:letterSpacing="-0.02" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="trending up ↗" android:textSize="12sp" android:textColor="@color/mint_deep" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="14dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1.4" android:orientation="vertical" android:background="@drawable/bg_glass_card" android:padding="18dp" android:layout_marginEnd="7dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AVG SCORE" android:textSize="10sp" android:textStyle="bold" android:textColor="@color/muted" android:letterSpacing="0.18" />
                <TextView android:id="@+id/avg_score_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textSize="44sp" android:textStyle="bold" android:textColor="@color/ink" android:letterSpacing="-0.04" android:layout_marginTop="2dp" />
                <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                <ProgressBar android:id="@+id/score_progress" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="8dp" android:progressDrawable="@drawable/progress_gold" android:progress="0" android:max="100" />
                <TextView android:id="@+id/stats_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 tests · 0 questions" android:textSize="11sp" android:textColor="@color/muted" android:layout_marginTop="8dp" />
            </LinearLayout>
            <LinearLayout android:id="@+id/btn_ai_chat" android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1" android:orientation="vertical" android:background="@drawable/bg_bento_lavender" android:foreground="?android:attr/selectableItemBackground" android:stateListAnimator="@animator/press_scale" android:clickable="true" android:focusable="true" android:padding="18dp" android:layout_marginStart="7dp">
                <TextView android:layout_width="42dp" android:layout_height="42dp" android:text="🤖" android:textSize="19sp" android:gravity="center" android:background="@drawable/bg_icon_circle" />
                <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Buddy" android:textSize="17sp" android:textStyle="bold" android:textColor="@color/ink" android:letterSpacing="-0.02" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="study assistant" android:textSize="12sp" android:textColor="@color/lavender_deep" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="made for JEE · works fully offline" android:textSize="12sp" android:textColor="@color/muted" android:gravity="center" android:layout_marginTop="28dp" android:layout_marginBottom="10dp" />
    </LinearLayout>
</ScrollView>
