<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Aurex Edge base theme -->
    <style name="Theme.AurexEdge" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_deep</item>
        <item name="colorOnPrimary">@color/ink</item>
        <item name="colorSecondary">@color/ink</item>
        <item name="colorSecondaryVariant">@color/ink</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:colorBackground">@color/bg_paper</item>
        <item name="android:windowBackground">@drawable/bg_screen</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.AurexEdge.Fullscreen" parent="Theme.AurexEdge">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Legacy aliases so older references keep working -->
    <style name="Theme.TestLabOffline" parent="Theme.AurexEdge" />
    <style name="Theme.TestLabOffline.Fullscreen" parent="Theme.AurexEdge.Fullscreen" />
</resources>
