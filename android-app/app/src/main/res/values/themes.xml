<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TestLabOffline" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorPrimaryVariant">@color/accent_yellow_dark</item>
        <item name="colorOnPrimary">@color/fg_black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_yellow</item>
        <item name="colorSecondaryVariant">@color/accent_yellow_dark</item>
        <item name="colorOnSecondary">@color/fg_black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowFullscreen">true</item>
        <!-- Customize your theme here. -->
        <item name="android:fontFamily">monospace</item>
    </style>
    
    <style name="Theme.TestLabOffline.Fullscreen" parent="Theme.TestLabOffline">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>