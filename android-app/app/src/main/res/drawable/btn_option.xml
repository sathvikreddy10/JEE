<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/gold_soft" />
            <stroke android:width="2dp" android:color="@color/gold" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#F2F2F5" />
            <stroke android:width="1dp" android:color="@color/border_strong" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
            <stroke android:width="1dp" android:color="@color/border" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
