generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Student {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  email     String?       @unique
  createdAt DateTime      @default(now())
  sessions  ExamSession[]
}

model QuestionSet {
  id        Int           @id @default(autoincrement())
  name      String
  subject   String
  pattern   String
  timeLimit Int
  questions Question[]
  sessions  ExamSession[]
}

model Question {
  id            Int             @id @default(autoincrement())
  setId         Int
  type          String
  text          String
  options       String?
  correctAnswer String
  explanation   String
  topic         String
  imageUrl      String?
  images        String?
  order         Int
  difficulty    String          @default("medium")
  set           QuestionSet     @relation(fields: [setId], references: [id])
  answers       StudentAnswer[]
}

model ExamSession {
  id           Int                    @id @default(autoincrement())
  setId        Int
  studentId    Int?
  studentName  String
  kind         String                 @default("regular")
  startTime    DateTime               @default(now())
  endTime      DateTime?
  timeLimit    Int
  completed    Boolean                @default(false)
  score        Int?
  total        Int?
  analytics    String?
  set          QuestionSet            @relation(fields: [setId], references: [id])
  student      Student?               @relation(fields: [studentId], references: [id])
  answers      StudentAnswer[]
  dailyAttempt DailyChallengeAttempt?
}

model StudentAnswer {
  id              Int         @id @default(autoincrement())
  sessionId       Int
  questionId      Int
  selectedOption  String?
  isCorrect       Boolean?
  timeSpent       Int         @default(0)
  markedForReview Boolean     @default(false)
  confidence      Int?
  session         ExamSession @relation(fields: [sessionId], references: [id])
  question        Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
}

model DailyChallenge {
  id          Int      @id @default(autoincrement())
  date        String   @unique
  questionIds String
  createdBy   String   @default("system")
  isManual    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model DailyChallengeAttempt {
  id          Int         @id @default(autoincrement())
  date        String
  sessionId   Int         @unique
  score       Int
  total       Int
  completedAt DateTime    @default(now())
  session     ExamSession @relation(fields: [sessionId], references: [id])
}
