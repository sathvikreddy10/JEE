# ─── Server ───
PORT=4000
DATABASE_URL=file:./prisma/dev.db

# ─── Frontend URL (used for cookie domain + secure flag) ───
# The cookie domain defaults to undefined for localhost/127.0.0.1/IPs
# (so LAN/Tailscale/ngrok access works) and to ".hostname" otherwise.
# The cookie's `secure` flag is set when this URL is https://.
FRONTEND_URL=http://localhost:3000

# ─── Session cookies ───
SESSION_COOKIE=testify_session
ADMIN_COOKIE=testify_admin
# Session TTL in days. 36500 = ~100 years (effectively forever).
# Sessions only auto-expire if a session's createdAt+TTL is in the past.
SESSION_TTL_DAYS=36500

# ─── Admin credentials (loaded from CSV) ───
ADMIN_CSV_PATH=data/admins.csv

# ─── Auth rate limit (only applies to non-localhost) ───
# Restart the backend to clear the in-memory rate-limit store.
AUTH_LIMIT=200
